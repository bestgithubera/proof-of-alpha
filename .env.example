# Copy to .env and fill in. NEVER commit .env.
CMC_API_KEY=put-your-key-here

# --- BNB Agent SDK (ERC-8004 registration, BSC Testnet) ---
# Password to encrypt/decrypt the agent keystore (~/.bnbagent/wallets/). You choose it.
WALLET_PASSWORD=choose-a-strong-password
# Leave PRIVATE_KEY unset to auto-generate a fresh agent wallet (recommended, zero real funds).
# PRIVATE_KEY=
# NETWORK=bsc-testnet
